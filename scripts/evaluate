#!/bin/bash
#
# Veto cross-platform launcher.
#
# Detects the current OS and dispatches to the appropriate platform-specific
# evaluate script:
#   - Linux:   evaluate.py  (Python 3)
#   - macOS:   evaluate.sh  (bash + curl)
#   - Windows: evaluate.sh  (bash + curl via Git Bash)
#
# Note: Claude Code always uses bash (Git Bash on Windows), so the bash+curl
# script works on both macOS and Windows. evaluate.ps1 is provided as a
# standalone option for use outside Claude Code.

# On Windows (Git Bash / MSYS), $0 may contain a Windows-style path
# (e.g. C:\Users\...) where backslashes are stripped by bash.
# Use cygpath to convert to a Unix-style path if available.
_self="$0"
if command -v cygpath >/dev/null 2>&1; then
    _self="$(cygpath -u "$0")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"

case "$OSTYPE" in
    linux*)
        # Linux -> Python
        python3 "$SCRIPT_DIR/evaluate.py"
        ;;
    *)
        # macOS, Windows (Git Bash), and others -> bash + curl
        bash "$SCRIPT_DIR/evaluate.sh"
        ;;
esac
